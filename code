import java.util.Scanner;
public class Unionoftwosortedarrays {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int m = sc.nextInt();
        int arr1[] = new int[n];
        int arr2[] = new int[m];
        for(int i=0;i<n;i++){
            arr1[i]=sc.nextInt();
        }
        for(int j=0;j<m;j++){
            arr2[j]=sc.nextInt();
        }
        int i=0,j=0;
        while(i<n&&j<m){
            if(arr1[i]<arr2[j]){
                System.out.print(arr1[i] + " ");
                i++;
            }
            else if(arr1[i]>arr2[j]){
                System.out.print(arr2[j] + " ");
                j++;
            }
            else{
                System.out.print(arr1[i] + " ");
                i++;
                j++;
            }
        }
        while(i<n){
            System.out.print(arr1[i] + " ");
            i++;
        }
        while(j<m){
            System.out.print(arr2[j] + " ");
            j++;
        }
    }
}
